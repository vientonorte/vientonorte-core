{
  "name": "@vientonorte/ui",
  "version": "0.3.1",
  "description": "Componentes UI del colectivo vientonorte — Atomic Design, a11y AA, --vn-* tokens",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/vientonorte/vientonorte-core.git",
    "directory": "packages/ui"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./button": {
      "import": "./dist/atoms/Button.js",
      "types": "./dist/atoms/Button.d.ts"
    },
    "./input": {
      "import": "./dist/atoms/Input.js",
      "types": "./dist/atoms/Input.d.ts"
    },
    "./badge": {
      "import": "./dist/atoms/Badge.js",
      "types": "./dist/atoms/Badge.d.ts"
    },
    "./label": {
      "import": "./dist/atoms/Label.js",
      "types": "./dist/atoms/Label.d.ts"
    },
    "./skeleton": {
      "import": "./dist/atoms/Skeleton.js",
      "types": "./dist/atoms/Skeleton.d.ts"
    },
    "./textarea": {
      "import": "./dist/atoms/Textarea.js",
      "types": "./dist/atoms/Textarea.d.ts"
    },
    "./switch": {
      "import": "./dist/atoms/Switch.js",
      "types": "./dist/atoms/Switch.d.ts"
    },
    "./checkbox": {
      "import": "./dist/atoms/Checkbox.js",
      "types": "./dist/atoms/Checkbox.d.ts"
    },
    "./progress": {
      "import": "./dist/atoms/Progress.js",
      "types": "./dist/atoms/Progress.d.ts"
    },
    "./card": {
      "import": "./dist/molecules/Card.js",
      "types": "./dist/molecules/Card.d.ts"
    },
    "./alert": {
      "import": "./dist/molecules/Alert.js",
      "types": "./dist/molecules/Alert.d.ts"
    },
    "./tabs": {
      "import": "./dist/molecules/Tabs.js",
      "types": "./dist/molecules/Tabs.d.ts"
    },
    "./dialog": {
      "import": "./dist/molecules/Dialog.js",
      "types": "./dist/molecules/Dialog.d.ts"
    },
    "./tooltip": {
      "import": "./dist/molecules/Tooltip.js",
      "types": "./dist/molecules/Tooltip.d.ts"
    },
    "./separator": {
      "import": "./dist/molecules/Separator.js",
      "types": "./dist/molecules/Separator.d.ts"
    },
    "./table": {
      "import": "./dist/molecules/Table.js",
      "types": "./dist/molecules/Table.d.ts"
    },
    "./alert-dialog": {
      "import": "./dist/molecules/AlertDialog.js",
      "types": "./dist/molecules/AlertDialog.d.ts"
    },
    "./select": {
      "import": "./dist/atoms/Select.js",
      "types": "./dist/atoms/Select.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.5.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "dependencies": {
    "@vientonorte/a11y": "file:../a11y"
  }
}